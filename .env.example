# Backend URL for server-side direct calls (SSR / Next API proxy)
# IMPORTANT (Docker): jangan pakai localhost kecuali backend jalan di container yang sama.
# Contoh:
# - same docker network: BACKEND_URL=http://payment-kita.backend:8080
# - backend di host machine: BACKEND_URL=http://host.docker.internal:8080
BACKEND_URL=
NEXT_PUBLIC_BACKEND_URL=

# Public API URL for browser-side/public HTTP client calls
NEXT_PUBLIC_API_URL=

# WalletConnect Project ID for AppKit (Sign in with Wallet)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# 32-character random string for JWE encryption
ENCRYPT_KEY=

# JWT Secret for verifying backend tokens (Must match backend)
JWT_SECRET=

# APP API KEY
ADMIN_API_KEY=
ADMIN_SECRET_KEY=

# Shared secret between frontend proxy and backend middleware
INTERNAL_PROXY_SECRET=

# Node ENV
NODE_ENV=
